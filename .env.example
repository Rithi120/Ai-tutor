GROQ_API_KEY=your_groq_api_key_here
APP_ENV=development
AI_MODE=live
# Required before development cached misses or live mode may call Groq.
ALLOW_LIVE_AI=false
AI_MOCK_SCENARIO=valid
AI_MOCK_LATENCY_MS=0
# Optional model pricing for local estimated-cost accounting.
AI_INPUT_COST_PER_MILLION=0
AI_OUTPUT_COST_PER_MILLION=0
AI_MAX_REQUESTS_PER_USER_HOUR=60
AI_MAX_REQUESTS_PER_USER_DAY=250
AI_MAX_LIVE_REQUESTS_DEVELOPMENT=20
AI_MAX_TOKENS_PER_SESSION=20000
AI_MAX_OUTPUT_CHARACTERS=200000
# Comma-separated usernames or emails allowed to view /internal/ai-diagnostics in development.
AI_DIAGNOSTICS_ADMINS=
# Per-task budgets use AI_<TASK>_MAX_INPUT_TOKENS and AI_<TASK>_MAX_OUTPUT_TOKENS.
AI_TUTOR_CHAT_MAX_OUTPUT_TOKENS=200
AI_ANSWER_EVALUATION_MAX_OUTPUT_TOKENS=250
AI_TRANSLATION_MAX_OUTPUT_TOKENS=400
AI_LESSON_GENERATION_MAX_OUTPUT_TOKENS=700
AI_QUIZ_GENERATION_MAX_OUTPUT_TOKENS=600
AI_PROJECT_SECTION_GENERATION_MAX_OUTPUT_TOKENS=1200
AI_FINAL_EXAM_GENERATION_MAX_OUTPUT_TOKENS=1200
AI_OCR_DOCUMENT_RECOGNITION_MAX_OUTPUT_TOKENS=1400
AI_ADAPTIVE_PRACTICE_MAX_OUTPUT_TOKENS=600
AI_FINAL_EXAM_EVALUATION_MAX_OUTPUT_TOKENS=600
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TUTOR_MODEL=openai/gpt-oss-20b
GROQ_FAST_MODEL=llama-3.1-8b-instant
LESSON_TOKEN_LIMIT=1800
ANSWER_TOKEN_LIMIT=1100
CHAT_TOKEN_LIMIT=350
TRANSLATE_TOKEN_LIMIT=2500
PROJECT_TOKEN_LIMIT=5000
SECRET_KEY=replace_with_a_long_random_value
DATABASE_URL=sqlite:///learnova.db
PORT=5000
RATELIMIT_STORAGE_URI=memory://
